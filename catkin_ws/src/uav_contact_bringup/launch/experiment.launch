<launch>
  <rosparam file="$(find uav_contact_bringup)/config/experiment.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/topics.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/task_manager.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/trajectory.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/contact_controller.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/uav_motion_controller.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/kinematics.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/servo.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/safety.yaml" command="load"/>

  <node pkg="uav_contact_core" type="task_manager_node.py" name="task_manager_node" output="screen"/>
  <node pkg="uav_contact_core" type="trajectory_server_node.py" name="trajectory_server" output="screen"/>
  <node pkg="uav_contact_core" type="end_effector_kinematics_node.py" name="end_effector_kinematics" output="screen"/>
  <node pkg="uav_contact_core" type="safety_monitor_node.py" name="safety_monitor" output="screen">
    <remap from="~state" to="/uav_contact/safety/state"/>
  </node>
  <node pkg="uav_contact_core" type="joint_servo_bridge.py" name="joint_servo_bridge" output="screen">
    <param name="publish_rate_hz" value="10.0"/>
    <param name="initial_pwm" value="1500"/>
  </node>
  <node pkg="uav_contact_core" type="dist_pid_controller.py" name="dist_pid_controller" output="screen">
    <param name="phase_enabled_topic" value="/uav_contact/phase_enabled"/>
    <param name="distance_topic" value="/uav_contact/distance"/>
  </node>

  <node pkg="rostopic" type="rostopic" name="baseline_velocity_ref_pub" args="pub -r 10 /uav_contact/velocity_ref geometry_msgs/Vector3 '{x: 0.0, y: 0.0, z: 0.0}'" output="screen"/>
  <node pkg="rostopic" type="rostopic" name="baseline_surface_normal_pub" args="pub -r 10 /uav_contact/surface_normal geometry_msgs/Vector3 '{x: 1.0, y: 0.0, z: 0.0}'" output="screen"/>
  <node pkg="rostopic" type="rostopic" name="baseline_safety_unsafe_pub" args="pub -r 10 /uav_contact/safety_unsafe std_msgs/Bool '{data: false}'" output="screen"/>
  <node pkg="uav_contact_core" type="uav_motion_controller_node" name="uav_motion_controller_node" output="screen">
    <remap from="velocity_ref" to="/uav_contact/velocity_ref"/>
    <remap from="velocity_normal_cmd" to="/uav_contact/velocity_normal_cmd"/>
    <remap from="surface_normal" to="/uav_contact/surface_normal"/>
    <remap from="safety_unsafe" to="/uav_contact/safety_unsafe"/>
  </node>
</launch>
