<launch>
  <arg name="namespace" default="uav_contact"/>
  <arg name="use_sim_time" default="false"/>
  <arg name="start_mavros" default="false"/>

  <param name="/use_sim_time" value="$(arg use_sim_time)"/>

  <rosparam file="$(find uav_contact_bringup)/config/experiment.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/topics.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/task_manager.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/trajectory.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/contact_controller.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/uav_motion_controller.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/kinematics.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/servo.yaml" command="load"/>
  <rosparam file="$(find uav_contact_bringup)/config/safety.yaml" command="load"/>

  <include if="$(arg start_mavros)" file="$(find mavros)/launch/px4.launch">
    <arg name="fcu_url" value="/dev/ttyACM0:57600"/>
  </include>

  <group ns="$(arg namespace)">
    <node pkg="uav_contact_core" type="task_manager_node.py" name="task_manager" output="screen"/>
    <node pkg="uav_contact_core" type="trajectory_server_node.py" name="trajectory_server" output="screen"/>
    <node pkg="uav_contact_core" type="dist_pid_controller.py" name="contact_controller" output="screen"/>
    <node pkg="uav_contact_core" type="uav_motion_controller_node" name="uav_motion_controller" output="screen"/>
    <node pkg="uav_contact_core" type="end_effector_kinematics_node.py" name="end_effector_kinematics" output="screen"/>
    <node pkg="uav_contact_core" type="joint_servo_bridge.py" name="joint_servo_bridge" output="screen"/>
    <node pkg="uav_contact_core" type="safety_monitor_node.py" name="safety_monitor" output="screen"/>
    <node pkg="uav_contact_core" type="experiment_data_recorder_node.py" name="experiment_data_recorder" output="screen"/>
  </group>
</launch>
